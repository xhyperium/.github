{
  "$schema_comment": "Org 级 Rust PR quality。modules 通过 jobs.org-rust.uses 调用可复用 workflow 时，GitHub 上报的 check 名为「调用方 job 名 / 被调用 job 名」，即 org-rust / rust-fmt 等（不是裸 rust-fmt）。仅对显式 include 的、已接入 ci-rust-org 的仓生效。enforcement=active。用 scripts/apply-org-ruleset.sh 应用到线上。",
  "name": "Rust PR quality (fmt/clippy/test)",
  "target": "branch",
  "enforcement": "active",
  "bypass_actors": [],
  "conditions": {
    "ref_name": {
      "include": ["~DEFAULT_BRANCH"],
      "exclude": []
    },
    "repository_name": {
      "include": ["infra.rs", "market_data.rs", "macro_data.rs"],
      "exclude": [".github", ".github-private"]
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "do_not_enforce_on_create": true,
        "required_status_checks": [
          { "context": "org-rust / rust-fmt" },
          { "context": "org-rust / rust-clippy" },
          { "context": "org-rust / rust-test" }
        ]
      }
    }
  ]
}
